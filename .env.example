# ── Application ──
APP_NAME=AI Job Apply Portal
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string-in-production

# ── MongoDB ──
MONGO_URL=mongodb://aijob:aijob_secret_2024@localhost:27017
MONGO_DB=ai_job_portal

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── JWT ──
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google Gemini AI ──
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ── Storage Paths ──
STORAGE_RESUMES=./storage/resumes
STORAGE_SCREENSHOTS=./storage/screenshots
STORAGE_LOGS=./storage/logs

# ── Automation ──
MAX_BROWSER_SESSIONS=3
DEFAULT_RATE_LIMIT_PER_SITE=5
APPLY_RETRY_MAX=2
CRAWL_INTERVAL_MINUTES=60

# ── Scoring Thresholds ──
SCORE_AUTO_APPLY=90
SCORE_MATCHED=75
SCORE_PARTIAL=60
